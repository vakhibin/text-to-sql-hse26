# =========================
# OpenRouter
# =========================
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# =========================
# Model policy
# =========================
GENERATOR_MODEL_PRIMARY=google/gemini-2.5-pro
GENERATOR_MODEL_SECONDARY=deepseek/deepseek-chat-v3
JUDGE_MODEL=openai/gpt-4.1
EMBEDDINGS_MODEL=openai/text-embedding-3-small

# =========================
# Data and retrieval
# =========================
SPIDER_ROOT=databases/spider
CHROMA_PERSIST_DIRECTORY=.cache/chroma
CHROMA_COLLECTION_SELECTOR=schema_selector

# =========================
# Ensemble defaults
# =========================
NUM_CANDIDATES=8
PRIMARY_CALLS=5
SECONDARY_CALLS=3

# =========================
# Selector defaults
# =========================
SELECTOR_TOP_K_TABLES=15
SELECTOR_TARGET_TABLES_MIN=3
SELECTOR_TARGET_TABLES_MAX=5

# =========================
# LLM generation defaults
# =========================
LLM_TEMPERATURE_PRIMARY=0.2
LLM_TEMPERATURE_SECONDARY=0.6
LLM_TEMPERATURE_JUDGE=0.0
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=90

# =========================
# Retry policy
# =========================
RETRY_ATTEMPTS=3
RETRY_WAIT_MIN_SECONDS=1
RETRY_WAIT_MAX_SECONDS=8

# =========================
# Refiner defaults
# =========================
MAX_REFINE_ATTEMPTS=3
